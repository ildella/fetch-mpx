  },
  "keywords": [
    "fetch",
    "http-client",
    "content-type",
    "dependency-injection",
    "esm"
  ],
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "exports": {
    ".": "./src/index.js",
